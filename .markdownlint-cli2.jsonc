{
  "config": {
    "default": true,
    "MD001": false,
    "MD013": false,
    "MD022": false,
    "MD024": {
      "siblings_only": true,
    },
    "MD031": false,
    "MD032": false,
    "MD033": false,
    "MD034": false,
    "MD040": false,
    "MD041": false,
    "MD047": false,
    "MD060": false,
  },
  "globs": [
    "AGENTS.md",
    "CLAUDE.md",
    "CODEX.md",
    "GEMINI.md",
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "LICENSE",
    ".cursorrules",
    ".factory/AGENTS.md",
    ".factory/skills/**/*.md",
    "docs/**/*.md",
    ".github/**/*.md",
  ],
  "ignores": ["node_modules/**"],
}
