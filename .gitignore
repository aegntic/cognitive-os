!.cursorrules
!CODEX.md
!GEMINI.md
!.gitignore
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE
!.env.example

# Allow .factory directory structure
!.factory/
!.factory/skills/
!.factory/skills/**
.gstack/

# Allow project tooling
!package.json
!package-lock.json
!tsconfig.json
!vitest.config.ts
!.markdownlint-cli2.jsonc
!.prettierrc
!.prettierignore
!.husky/
!.husky/**

# Allow tests
!tests/
!tests/**

# Allow docs
!docs/
!docs/**

# Allow GitHub infrastructure
!.github/
!.github/**
!.devcontainer/
!.devcontainer/**

# Dependencies (never commit)
node_modules/

# Showcase projects (very early / WIP - Insidher etc.)
!02_Showcase/
!02_Showcase/**

# Brik Pro - local-first agentic design tool (Vite + IndexedDB + LLM)
!brik-pro/
!brik-pro/**
brik-pro/node_modules/
brik-pro/dist/

# Landing page (Next.js)
